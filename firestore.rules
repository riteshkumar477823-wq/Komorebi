// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required)
//   - displayName: string
//   - email: string (required)
//   - streakCount: number
//   - lastActiveDate: timestamp
//   - dailyGoalMet: boolean
//   - xp: number
//   - rank: string
//   - title: string
//   - dailyGoal: number
//   - avatar: string
//   - ownedAvatars: list
//   - preferredTTS: string
//   - notificationsEnabled: boolean
//   - achievements: list
//   - pinnedAchievements: list
//   - apiKeys: list
//   - quoteCache: list
//   - quoteStats: map
//
// Collection: users/{userId}/vocabularies
// Document ID: {vocabId}
// Fields:
//   - uid: string (required)
//   - japanese: string (required, max 100)
//   - meaning: string (required, max 500)
//   - romaji: string (max 100)
//   - createdAt: timestamp (required)
//   - mastery: number (0-5)
//   - parentId: string
//   - type: string
//   - deleted: boolean
//
// Collection: users/{userId}/notes
// Document ID: {noteId}
// Fields:
//   - title: string (required)
//   - content: string (required)
//   - createdAt: timestamp (required)
//   - updatedAt: timestamp (required)
//   - color: string
//
// Collection: users/{userId}/discovered_words
// Document ID: {wordId}
// Fields:
//   - jp: string (required)
//   - ro: string
//   - en: string (required)
//   - createdAt: timestamp
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "riteshkumar477823@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      let allowedFields = [
        'uid', 'displayName', 'email', 'streakCount', 'lastActiveDate', 
        'dailyGoalMet', 'xp', 'rank', 'title', 'dailyGoal', 'avatar', 
        'ownedAvatars', 'preferredTTS', 'notificationsEnabled', 'achievements', 
        'pinnedAchievements', 'apiKeys', 'quoteCache', 'quoteStats', 'role', 'theme'
      ];
      return data.keys().hasAll(['uid', 'email']) &&
             data.keys().hasOnly(allowedFields) &&
             data.uid is string &&
             data.email is string &&
             (!('displayName' in data) || (data.displayName is string || data.displayName == null)) &&
             (!('streakCount' in data) || data.streakCount is number) &&
             (!('xp' in data) || data.xp is number) &&
             (!('lastActiveDate' in data) || data.lastActiveDate is timestamp) &&
             (!('dailyGoalMet' in data) || data.dailyGoalMet is bool) &&
             (!('rank' in data) || data.rank is string) &&
             (!('title' in data) || data.title is string) &&
             (!('dailyGoal' in data) || data.dailyGoal is number) &&
             (!('avatar' in data) || data.avatar is string) &&
             (!('ownedAvatars' in data) || data.ownedAvatars is list) &&
             (!('preferredTTS' in data) || data.preferredTTS in ['native', 'gemini']) &&
             (!('notificationsEnabled' in data) || data.notificationsEnabled is bool) &&
             (!('achievements' in data) || data.achievements is list) &&
             (!('pinnedAchievements' in data) || data.pinnedAchievements is list) &&
             (!('apiKeys' in data) || data.apiKeys is list) &&
             (!('quoteCache' in data) || data.quoteCache is list) &&
             (!('quoteStats' in data) || data.quoteStats is map) &&
             (!('role' in data) || data.role in ['admin', 'user', 'client']) &&
             (!('theme' in data) || data.theme in ['light', 'dark', 'system']);
    }

    function isValidVocab(data) {
      let allowedFields = ['uid', 'japanese', 'meaning', 'romaji', 'createdAt', 'mastery', 'parentId', 'type', 'deleted'];
      return data.keys().hasAll(['uid', 'japanese', 'meaning', 'createdAt']) &&
             data.keys().hasOnly(allowedFields) &&
             data.uid == request.auth.uid &&
             data.japanese is string && data.japanese.size() <= 100 &&
             data.meaning is string && data.meaning.size() <= 500 &&
             (!('romaji' in data) || (data.romaji is string && data.romaji.size() <= 100)) &&
             (!('mastery' in data) || data.mastery is number) &&
             (!('parentId' in data) || data.parentId is string) &&
             (!('type' in data) || data.type in ['main', 'sub']) &&
             (!('deleted' in data) || data.deleted is bool) &&
             data.createdAt is timestamp;
    }

    function isValidNote(data) {
      let allowedFields = ['title', 'content', 'createdAt', 'updatedAt', 'color', 'isPinned'];
      return data.keys().hasAll(['title', 'content', 'createdAt', 'updatedAt']) &&
             data.keys().hasOnly(allowedFields) &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 5000 &&
             (!('color' in data) || data.color is string) &&
             (!('isPinned' in data) || data.isPinned is bool) &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidDiscoveredWord(data) {
      let allowedFields = ['jp', 'ro', 'en', 'createdAt'];
      return data.keys().hasAll(['jp', 'en']) &&
             data.keys().hasOnly(allowedFields) &&
             data.jp is string && data.jp.size() <= 100 &&
             data.en is string && data.en.size() <= 500 &&
             (!('ro' in data) || (data.ro is string && data.ro.size() <= 100)) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);

      match /vocabularies/{vocabId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidVocab(request.resource.data);
        allow update: if isOwner(userId) && isValidVocab(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /notes/{noteId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidNote(request.resource.data);
        allow update: if isOwner(userId) && isValidNote(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /discovered_words/{wordId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidDiscoveredWord(request.resource.data);
        allow update: if isOwner(userId) && isValidDiscoveredWord(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
