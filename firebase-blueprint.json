{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and learning progress",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "streakCount": { "type": "integer" },
        "lastActiveDate": { "type": "string", "format": "date-time" },
        "dailyGoalMet": { "type": "boolean" },
        "xp": { "type": "integer" },
        "rank": { "type": "string" },
        "title": { "type": "string" },
        "dailyGoal": { "type": "integer" },
        "avatar": { "type": "string" },
        "ownedAvatars": { "type": "array", "items": { "type": "string" } },
        "preferredTTS": { "type": "string", "enum": ["native", "gemini"] },
        "notificationsEnabled": { "type": "boolean" },
        "achievements": { "type": "array", "items": { "type": "string" } },
        "pinnedAchievements": { "type": "array", "items": { "type": "string" } },
        "apiKeys": { "type": "array", "items": { "type": "string" } },
        "quoteCache": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "text": { "type": "string" },
              "translation": { "type": "string" }
            }
          } 
        },
        "quoteStats": {
          "type": "object",
          "properties": {
            "lastDate": { "type": "string" },
            "count": { "type": "integer" }
          }
        },
        "role": { "type": "string", "enum": ["admin", "user", "client"] },
        "theme": { "type": "string", "enum": ["light", "dark", "system"] }
      },
      "required": ["uid", "email"]
    },
    "Vocabulary": {
      "title": "Vocabulary",
      "description": "Japanese words added by the user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "japanese": { "type": "string" },
        "meaning": { "type": "string" },
        "romaji": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "mastery": { "type": "integer" },
        "parentId": { "type": "string" },
        "type": { "type": "string", "enum": ["main", "sub"] }
      },
      "required": ["uid", "japanese", "meaning"]
    },
    "Note": {
      "title": "Note",
      "description": "User's personal notes",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "color": { "type": "string" },
        "isPinned": { "type": "boolean" }
      },
      "required": ["title", "content", "createdAt", "updatedAt"]
    },
    "DiscoveredWord": {
      "title": "DiscoveredWord",
      "description": "Words discovered by the user in the dictionary",
      "type": "object",
      "properties": {
        "jp": { "type": "string" },
        "ro": { "type": "string" },
        "en": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["jp", "ro", "en"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/vocabularies/{vocabId}": {
      "schema": "Vocabulary",
      "description": "User's personal vocabulary list"
    },
    "/users/{userId}/notes/{noteId}": {
      "schema": "Note",
      "description": "User's personal notes"
    },
    "/users/{userId}/discovered_words/{wordId}": {
      "schema": "DiscoveredWord",
      "description": "Words discovered in the dictionary"
    }
  }
}
